# Copy this file to .env and fill in ONE provider's key to enable LLM-polished
# AI Insights briefings. Never commit the real .env file (it's gitignored).
#
# Not required to run or score this project: with no key set, the app still
# runs fully offline and produces a deterministic, grounded briefing — every
# tab and the scored pipeline (run.sh) work with zero API keys.
#
# Provider auto-detection order: Gemini -> OpenAI -> Anthropic (first key found
# wins). Set AIGNITION_LLM_PROVIDER below to force a specific one.

# --- Gemini (default provider; SDK already in requirements-app.txt) ---
GEMINI_API_KEY=

# --- OpenAI (uncomment `openai` in requirements-app.txt to use) ---
# OPENAI_API_KEY=

# --- Anthropic (uncomment `anthropic` in requirements-app.txt to use) ---
# ANTHROPIC_API_KEY=

# Optional overrides:
# AIGNITION_LLM_PROVIDER=auto      # auto | gemini | openai | anthropic
# AIGNITION_GEMINI_MODEL=gemini-2.5-flash
# AIGNITION_OPENAI_MODEL=gpt-4o-mini
# AIGNITION_ANTHROPIC_MODEL=claude-3-5-haiku-latest
